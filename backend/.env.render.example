AUTOCAR_APP_NAME=AutoCar Admin API
AUTOCAR_ENVIRONMENT=production
AUTOCAR_DEBUG=false
AUTOCAR_API_PREFIX=/api
AUTOCAR_USE_MOCK_DATA=false
AUTOCAR_CORS_ORIGINS=["https://your-vercel-app.vercel.app"]
AUTOCAR_SUPABASE_URL=https://your-project.supabase.co
AUTOCAR_SUPABASE_KEY=your-service-role-key
AUTOCAR_SUPABASE_STORAGE_BUCKET=service-images
AUTOCAR_KEEPALIVE_ENABLED=true
AUTOCAR_KEEPALIVE_INTERVAL_DAYS=5
AUTOCAR_KEEPALIVE_TABLE=clients
